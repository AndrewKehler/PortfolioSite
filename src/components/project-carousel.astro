<div class="container">
    <div class="header">
        <div class="spacer"></div>
        <h1>Recent Projects</h1>
    </div>
    <div class="carousel-contain">
        <div class="carousel-track">
            <div class="project p1">1</div>
            <div class="project">2</div>
            <div class="project">3</div>
            <div class="project"></div>
            <div class="project"></div>
            <div class="project"></div>    
        </div>
        
        
    </div>
</div>

<style>
    .container{
        overflow: hidden;
    }
    .header{
        display: flex;
        align-items: center;
        gap: 3%;
        background-color: rgb(250, 250, 250);
    }
    .spacer{
        background-color: #4988DC;
        height: .4vw;
        width: 5.5vw;
        margin: 3px 0 0 4%;
    }
    h1{
        font-family:"Intel One Mono", monospace;
        font-weight: 400;
        font-size: clamp(1.8rem, 2.5vw, 3.3rem)
    }
    .carousel-container{
        width: 100%;
        overflow: hidden;
    }
    .carousel-track{      
        height: 25vw;
        display: flex;
        gap: 3vw;
        align-items: center;
        
    }
    .carousel-track>:nth-child(odd){
        width: 20vw;
        height: 20vw;
        background: rgb(159, 179, 197);
        flex: 0 0 20vw;
    }
    .carousel-track>:nth-child(even){
        width: 20vw;
        height: 20vw;
        background: rgb(205, 215, 223);
        flex: 0 0 20vw;
    }

</style>

<style>
    @media screen and (max-width:780px){
        .carousel-track{ 
            height: 50vw;
            gap: 5vw;
        }
        .carousel-track>:nth-child(odd){
            width: 40vw;
            height: 40vw;
            flex: 0 0 40vw;
        }
        .carousel-track>:nth-child(even){
            width: 40vw;
            height: 40vw;
            flex: 0 0 40vw;
        }

    }

</style>

<script>
    import {horizontalLoop} from '../utils/horizontalLoop';
    const projects = gsap.utils.toArray('.project');

    const track = document.querySelector(".carousel-track");
    const gap = track ? window.getComputedStyle(track).gap: "0"; 
    const gapVal = parseFloat(gap) || 0;

    const loop = horizontalLoop(projects, {
        pause:false,
        repeat:-1,
        speed:1,
        paddingRight: gapVal,
        reversed: true
    });

    projects.forEach((prjct: { addEventListener: (arg0: string, arg1: () => void) => void; })=> {
        prjct.addEventListener("mouseenter", () => {
            gsap.to(loop, { timeScale: -.5, duration: 0.5, overwrite: true });
            gsap.to(prjct, { scale: 1.1, duration: 0.5, ease: "power2.out", overwrite: "auto" });
        });

        prjct.addEventListener("mouseleave", () => {
            gsap.to(loop, { timeScale: -1, duration: 0.5, overwrite: true });
            gsap.to(prjct, { scale: 1, duration: 0.3, ease: "power2.out",overwrite: "auto"  });
        });
    });

</script>