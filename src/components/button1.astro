---

<button>
    <slot></slot>
</button>

<style>
    button{
        width: 35%;
        padding: .4em 0 .4em 0;
        border: 0;
        box-shadow: inset 0 0 0 0em #5D5C69; 
        font-size: clamp(1em, calc(2vw + 1em), 3em);
        font-family: "Graduate", serif;
        color: white;
        background-color: #5D5C69;
        
        border-radius: 80px;
        transition: background-color .5s, color .5s, box-shadow .5s;
        cursor: pointer;
        /* transition: color 500ms ease-in-out; */
    }

    button:hover{
        box-shadow: inset 0 0 0 .2em #5D5C69; 
        /* border: 10px inset #5D5C69; */
        color: #5D5C69;
        background-color: white;
    }
</style>

<style>
     @media screen and (max-width:780px) {
       button{
            font-size: 5vw;
       }
     }

</style>