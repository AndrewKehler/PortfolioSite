---
const squares = [
    {id:0, width:"80%", colour:"#E2EEF2", top: "20%", left:"10%"},
    {id:1, width:"24%", colour: "#969BCB", top:"36%", left:"5%"},
    {id:1, width:"24%", colour: "#969BCB", top:"76%", left:"5%"},
    {id:1, width:"24%", colour: "#969BCB", top:"6%", left:"60%"},
    {id:1, width:"24%", colour: "#969BCB", top:"63%", left:"72%"},
    {id:2, width:"13%", colour: "#A2AAF3", top:"11%", left:"20%"},
    {id:2, width:"13%", colour: "#A2AAF3", top:"-2%", left:"40%"},
      {id:2, width:"13%", colour: "#A2AAF3", top:"90%", left:"-14%"},
    {id:3, width:"11%", colour:"#CED2F6", top:"63%", left:"24%"}
];
---

<div class="container" aria-hidden="true">
    {squares.map((square) =>(
        <div
            class=`${square.id}`
            style=`
                position:absolute;
                width:${square.width}; 
                height:${square.width}; 
                background:${square.colour};
                top:${square.top};
                left:${square.left};`
        ></div>

    ))}

</div>

<style>
    .container{
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        z-index: -1;
        
        
    }
    .1{
        background-color: #969BCB;
        height: auto;
    }
    .2{
        background-color: #A2AAF3;
        height: auto;
    }
    .3{
        background-color: #CED2F6;
        height: auto;
    }
</style>